# ============================================================
# LLM 配置 (默认 DashScope，可切换 OpenAI / DeepSeek 等)
# ============================================================
# API Key
#   DashScope: https://dashscope.console.aliyun.com/apiKey
#   OpenAI:    https://platform.openai.com/api-keys
#   DeepSeek:  https://platform.deepseek.com/api_keys
LLM_API_KEY=your-api-key-here

# API 地址 (不填默认 DashScope)
#   切换示例:
#     OpenAI:   https://api.openai.com/v1
#     DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=

# 文本 LLM 模型
#   DashScope: qwen-plus / qwen-turbo / qwen-max
#   OpenAI:    gpt-4o / gpt-4.1
#   DeepSeek:  deepseek-chat / deepseek-reasoner
LLM_MODEL=qwen-plus

# 多模态视觉模型 (医学图像分类)
#   DashScope: qwen-vl-plus / qwen-vl-max
#   OpenAI:    gpt-4o
VISION_MODEL=qwen-vl-plus

# Embedding 模型
EMBEDDING_MODEL=text-embedding-v3
# Embedding 独立配置 (不填默认跟随 LLM_BASE_URL / LLM_API_KEY)
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=

# ---- 以下可选 ----
# Eleven Labs 语音 API (STT + TTS)
ELEVEN_LABS_API_KEY=

# Tavily 网络搜索 API
TAVILY_API_KEY=

# Hugging Face Token (Cross-Encoder 重排序)
HUGGINGFACE_TOKEN=

# 部署
HOST=0.0.0.0
PORT=8080

# 日志级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
